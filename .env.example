# ============================================================================
# GOALMIND AI - Variables d'environnement
# ============================================================================
# Copiez ce fichier vers .env et remplissez vos propres clés API.
# Toutes les clés sont OPTIONNELLES — l'app fonctionne en mode dégradé
# avec TheSportsDB (gratuit, sans clé). Plus vous ajoutez de clés, plus
# les données seront précises et nombreuses.

# ============================================================================
# REQUIS - Base de données
# ============================================================================
DATABASE_URL="postgresql://postgres:postgres@127.0.0.1:5432/app_db"

# ============================================================================
# OPTIONNEL - API Football Data (football-data.org)
# ============================================================================
# 📝 Inscription gratuite : https://www.football-data.org/client/register
# 📊 Plan gratuit : 10 requêtes/minute, historique complet des matchs
# 💡 Apporte : résultats historiques (plusieurs saisons), calendriers,
#    classements complets (20 équipes par ligue)
FOOTBALL_DATA_API_KEY=""

# ============================================================================
# OPTIONNEL - API-Football via RapidAPI
# ============================================================================
# 📝 Inscription : https://rapidapi.com/api-sports/api/api-football
# 📊 Plan gratuit : 100 requêtes/jour
# 💡 Apporte : cotes bookmaker en temps réel, stats détaillées, lineups,
#    événements live, xG, statistiques par match
RAPIDAPI_KEY=""

# ============================================================================
# OPTIONNEL - The Odds API
# ============================================================================
# 📝 Inscription : https://the-odds-api.com/
# 📊 Plan gratuit : 500 requêtes/mois
# 💡 Apporte : VRAIES cotes bookmaker agrégées depuis 50+ bookmakers
#    (Bet365, Unibet, Pinnacle, etc.) pour calculer les value bets précis
ODDS_API_KEY=""

# ============================================================================
# OPTIONNEL - RapidAPI Host (auto-détecté)
# ============================================================================
# Ne modifiez pas sauf si vous changez de provider
RAPIDAPI_HOST="api-football-v1.p.rapidapi.com"

# ============================================================================
# OPTIONNEL - Microservice Python ML réel XGBoost / LightGBM / CatBoost
# ============================================================================
# Déployez le dossier ml_service/ sur Render comme Web Service Docker.
# Exemple: ML_SERVICE_URL="https://goalmind-ml-service.onrender.com"
# Si absent, Next.js utilise automatiquement l'ensemble TypeScript local.
ML_SERVICE_URL=""
